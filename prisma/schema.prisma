generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Profile {
  id             String   @id @default(cuid())
  name           String
  designation    String
  headline       String
  tagline        String
  availability   String
  location       String
  currentCompany String
  photoUrl       String
  resumeUrl      String
  footerTagline  String
  stats          Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AboutMe {
  id        String   @id @default(cuid())
  content   String
  imageUrl  String
  since     String
  facts     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String   @unique
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id          String   @id @default(cuid())
  name        String
  category    String
  proficiency Int?
  icon        String?
  tag         String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([name, category])
}

model Education {
  id        String   @id @default(cuid())
  year      String
  school    String
  degree    String
  note      String
  icon      String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Experience {
  id        String   @id @default(cuid())
  range     String
  company   String
  role      String
  location  String
  bullets   String[]
  stack     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  year        String
  tag         String
  imageUrl    String
  summary     String
  techStack   String[]
  liveUrl     String?
  githubUrl   String?
  challenges  String
  futurePlans String
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactInfo {
  id        String   @id @default(cuid())
  email     String
  phone     String
  whatsapp  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id            String    @id @default(cuid())
  name          String
  email         String
  subject       String
  message       String
  source        String    @default("contact-form")
  inboundTo     String?
  status        String    @default("unread")
  replySubject  String?
  replyBody     String?
  repliedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model AdminAccount {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
